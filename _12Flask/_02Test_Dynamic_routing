from flask import Flask,request

app=Flask(__name__)

@app.route("/home/<name>/<int:age>",methods=["GET","POST"])
def home(name,age):
    s= f"""
    <h1>Welcome {name}!</h1>
   <p>You are {age} years old.</p>"""
    if request.method == "GET":
        return f"Method : GET {s}"
    return f"Method : POST {s}"

if __name__ == "__main__":
    app.run(debug=True)